# RepairShop systemd environment
# This file is sourced by systemd — it reads the main config
# and passes environment variables to the Node.js process.
#
# Do not edit this file directly.
# Edit /etc/repairshop/repairshop.conf instead, then:
#   sudo systemctl restart repairshop

# Source the main config file
# (systemd EnvironmentFile does not support sourcing — variables
#  are loaded directly from this file. Kept in sync by the
#  repairshop-config-sync script or by editing both files.)

PORT=3000
HTTPS_PORT=3443
DB_PATH=/var/lib/repairshop/repairshop.sqlite
UPLOADS_PATH=/var/lib/repairshop/uploads
SSL_CERT=/var/lib/repairshop/ssl/cert.pem
SSL_KEY=/var/lib/repairshop/ssl/key.pem
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_BEFORE_FIRST_USE
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/appointments/google/callback
NODE_ENV=production
